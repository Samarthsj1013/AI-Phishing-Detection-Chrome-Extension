{
  "manifest_version": 3,
  "name": "PhishGuard AI",
  "version": "2.0",
  "description": "Real-time phishing detection powered by Machine Learning",
  "permissions": ["tabs", "activeTab"],
  "host_permissions": [
    "http://127.0.0.1:5000/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "PhishGuard AI"
  }
}