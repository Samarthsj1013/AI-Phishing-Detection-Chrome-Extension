{
  "manifest_version": 3,
  "name": "PhishGuard AI",
  "version": "2.0",
  "description": "Real-time phishing detection powered by Machine Learning and VirusTotal",
  "permissions": ["tabs", "activeTab", "storage", "scripting"],
  "host_permissions": [
    "https://ai-phishing-detection-chrome-extension-1.onrender.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "PhishGuard AI",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}